{
  "name": "webgenome-crawler",
  "version": "0.1.0",
  "private": true,
  "description": "WebGenome G2 crawler API and Playwright worker",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.1",
    "bullmq": "^5.34.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "mongodb": "^6.12.0",
    "playwright": "^1.60.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
