# Railway crawler API
PORT=4000
CRAWLER_CONCURRENCY=2
MAX_PAGES_PER_CRAWL=50
START_WORKER=true

# BullMQ requires Redis protocol credentials, not Upstash REST credentials.
# Option A - single URL (Railway/Upstash recommended)
REDIS_URL=rediss://:your-password@apt-xxxxx.upstash.io:6379

# Option B - individual vars (local docker-compose, manual Redis, etc.)
# REDIS_HOST=apt-xxxxx.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-upstash-redis-password
# REDIS_TLS=true

# Optional MongoDB storage. If omitted, crawl records/pages are stored in Redis.
MONGODB_URI=mongodb+srv://webgenome-api:<password>@webgenome.xxxxx.mongodb.net/webgenome?retryWrites=true&w=majority
MONGODB_DB_NAME=webgenome

# Optional Cloudflare R2 screenshot storage. If omitted, screenshots are skipped.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=webgenome-screenshots
R2_PUBLIC_URL=
